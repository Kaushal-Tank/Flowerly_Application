<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FlowerlyShoppingApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.FlowerlyShoppingApp" parent="Base.Theme.FlowerlyShoppingApp" />

    <!-- Custom Search bar -->
    <style name="CustomSearchBarStyle" parent="Widget.Material3.SearchBar">
        <item name="android:radius">2dp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="strokeColor">@color/mint_mist</item>
        <item name="strokeWidth">1dp</item>
        <item name="shapeAppearance">@style/CustomSearchBarShape</item>
    </style>

    <style name="CustomSearchBarShape" parent="ShapeAppearance.Material3.Corner.None">
        <item name="cornerSize">6dp</item>
    </style>

    <!-- Bottom Navigation bar -->
    <style name="BottomNavText">
        <item name="android:textSize">14sp</item>
        <item name="fontFamily">@font/merriweather_variable_font</item>
        <item name="android:textFontWeight">500</item>
    </style>

    <style name="BottomNavIcon" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorSecondaryContainer">@android:color/transparent</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
    </style>

</resources>